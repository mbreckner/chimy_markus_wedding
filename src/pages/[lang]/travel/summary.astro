---
export const prerender = true;

import Layout from '../../../layouts/Layout.astro';
import { t, languages } from '../../../i18n';
import type { Lang } from '../../../i18n';

export function getStaticPaths() {
    return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);
const tv = tr.travel;
const vt = tv.voting;

const sections = [
    { key: 'serengeti',   label: tv.destinations[1].name, number: '02' },
    { key: 'ngorongoro',  label: tv.destinations[2].name, number: '03' },
    { key: 'zanzibar',    label: tv.destinations[3].name, number: '04' },
];
---

<Layout lang={lang} page="travel">
    <style>
        .summary-table-wrap { overflow-x: auto; }
        .summary-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .summary-table th {
            font-size: 9px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--gold);
            font-weight: 400;
            padding: 0.6rem 1rem;
            text-align: left;
            border-bottom: 1px solid var(--divider);
            white-space: nowrap;
        }
        .summary-table td {
            padding: 0.75rem 1.25rem;
            border-bottom: 1px solid var(--divider);
            color: var(--text-mid);
            vertical-align: middle;
        }
        .summary-table tr:last-child td { border-bottom: none; }
        .summary-table tbody tr:hover td { background: var(--ivory-dark); }
        .summary-name {
            font-size: 13px;
            color: var(--text-dark);
            font-weight: 400;
            white-space: nowrap;
            min-width: 160px;
        }
        .vote-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.4rem 1rem;
            border: 1px solid;
            font-family: 'Jost', sans-serif;
            font-size: 10px;
            font-weight: 400;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }
        .vote-tag-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }
        .vote-tag--count-me-in {
            color: #4a7c59;
            background: #eef4f0;
            border-color: #4a7c59;
        }
        .vote-tag--still-deciding {
            color: var(--gold);
            background: var(--gold-light);
            border-color: var(--gold);
        }
        .summary-section-block { margin-top: 3rem; }
        .summary-section-header { margin-bottom: 1rem; }
        .summary-section-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            font-weight: 300;
            color: var(--burgundy);
            font-style: italic;
        }
        .summary-section-number {
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-light);
            margin-right: 0.5rem;
        }
        .summary-totals {
            font-size: 11px;
            color: var(--text-light);
            margin-top: 0.25rem;
        }
        .no-votes { font-size: 13px; color: var(--text-light); font-style: italic; padding: 0.5rem 0; }
        .summary-loading { font-size: 13px; color: var(--text-light); font-style: italic; }
    </style>

    <div class="page-header">
        <p class="page-eyebrow">{tv.eyebrow}</p>
        <h1 class="page-title">{tv.title}</h1>
    </div>

    <div class="content" id="summary-content">
        {sections.map(section => (
            <div class="summary-section-block" id={`section-${section.key}`}>
                <div class="summary-section-header">
                    <div>
                        <span class="summary-section-number">{section.number}</span>
                        <span class="summary-section-name">{section.label}</span>
                    </div>
                    <p class="summary-totals" id={`totals-${section.key}`}></p>
                </div>
                <div id={`table-${section.key}`}>
                    <p class="summary-loading">Loading…</p>
                </div>
            </div>
        ))}
    </div>

    <script define:vars={{ sections, countMeInLabel: vt.countMeInList, stillDecidingLabel: vt.stillDecidingList, noVotesLabel: vt.noVotesYet }}>
        async function loadSection(section) {
            const res = await fetch(`/api/votes?section=${section.key}`);
            if (!res.ok) return;
            const votes = await res.json();

            const countMeIn = votes.filter(v => v.status === 'count_me_in');
            const stillDeciding = votes.filter(v => v.status === 'still_deciding');

            document.getElementById(`totals-${section.key}`).textContent =
                `${countMeIn.length} × ${countMeInLabel}  ·  ${stillDeciding.length} × ${stillDecidingLabel}`;

            const tableEl = document.getElementById(`table-${section.key}`);
            if (votes.length === 0) {
                tableEl.innerHTML = `<p class="no-votes">${noVotesLabel}</p>`;
                return;
            }

            const sorted = [...votes].sort((a, b) => {
                if (a.status === b.status) return a.name.localeCompare(b.name);
                return a.status === 'count_me_in' ? -1 : 1;
            });

            tableEl.innerHTML = `
                <div class="summary-table-wrap">
                    <table class="summary-table">
                        <thead><tr><th>Name</th><th>Vote</th></tr></thead>
                        <tbody>
                            ${sorted.map(v => `
                                <tr>
                                    <td class="summary-name">${escapeHtml(v.name)}</td>
                                    <td><span class="vote-tag vote-tag--${v.status === 'count_me_in' ? 'count-me-in' : 'still-deciding'}">
                                        <span class="vote-tag-dot"></span>
                                        ${v.status === 'count_me_in' ? countMeInLabel : stillDecidingLabel}
                                    </span></td>
                                </tr>`).join('')}
                        </tbody>
                    </table>
                </div>`;
        }

        function escapeHtml(str) {
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        sections.forEach(loadSection);
    </script>
</Layout>
