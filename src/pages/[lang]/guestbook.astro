---
import Layout from '../../layouts/Layout.astro';
import { t, languages } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
    return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);
const gb = tr.guestbook;
---

<Layout lang={lang} page="guestbook">
    <style>
        .messages-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
        .message-card { padding: 1.5rem; border: 1px solid var(--divider); background: var(--ivory); position: relative; }
        .message-card::before { content: '\201C'; font-family: 'Cormorant Garamond', serif; font-size: 64px; color: var(--gold-light); position: absolute; top: 0.5rem; left: 1rem; line-height: 1; font-weight: 300; pointer-events: none; }
        .msg-name { font-size: 11px; font-weight: 500; color: var(--burgundy); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem; }
        .msg-text { font-size: 14px; color: var(--text-mid); line-height: 1.7; font-style: italic; }
        .msg-date { font-size: 11px; color: var(--text-light); margin-top: 0.75rem; }
        @media (max-width: 640px) { .messages-grid { grid-template-columns: 1fr; } }
    </style>

    <div class="page-header">
        <p class="page-eyebrow">{gb.eyebrow}</p>
        <h1 class="page-title">{gb.title}</h1>
    </div>

    <div class="content">
        <div class="messages-grid" id="messages-list">
            {gb.sampleMessages.map(msg => (
                    <div class="message-card">
                        <p class="msg-name">{msg.name}</p>
                        <p class="msg-text">{msg.text}</p>
                        <p class="msg-date">{msg.date}</p>
                    </div>
            ))}
        </div>

        <div class="form-section">
            <h3 class="form-title">{gb.formTitle}</h3>
            <p class="form-desc">{gb.formDesc}</p>
            <div class="form-row"><label>{gb.nameLabel}</label><input type="text" id="g-name" placeholder={gb.namePlaceholder} /></div>
            <div class="form-row"><label>{gb.messageLabel}</label><textarea id="g-text" placeholder={gb.messagePlaceholder}></textarea></div>
            <button class="btn-submit" id="g-submit">{gb.submitBtn}</button>
            <div class="form-success" id="g-success">{gb.successMsg}</div>
        </div>
    </div>

    <script>
        document.getElementById('g-submit')?.addEventListener('click', () => {
            const name = (document.getElementById('g-name') as HTMLInputElement)?.value.trim();
            const text = (document.getElementById('g-text') as HTMLTextAreaElement)?.value.trim();
            if (!name || !text) return;
            const list = document.getElementById('messages-list');
            if (list) {
                const card = document.createElement('div');
                card.className = 'message-card';
                card.innerHTML = `<p class="msg-name">${name}</p><p class="msg-text">${text}</p><p class="msg-date">Just now</p>`;
                list.prepend(card);
            }
            const success = document.getElementById('g-success');
            if (success) success.style.display = 'block';
            (document.getElementById('g-name') as HTMLInputElement).value = '';
            (document.getElementById('g-text') as HTMLTextAreaElement).value = '';
        });
    </script>
</Layout>