---
import Layout from '../../layouts/Layout.astro';
import { t, languages } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
    return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);
const qa = tr.qa;
const gb = tr.guestbook;
---

<Layout lang={lang} page="qa">
    <style>
        .qa-item { border-bottom: 1px solid var(--divider); }
        .qa-q { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 400; color: var(--text-dark); cursor: pointer; display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 0; gap: 1rem; user-select: none; }
        .qa-toggle { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--divider); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--gold); font-size: 20px; transition: all 0.2s; background: var(--ivory); line-height: 1; }
        .qa-item.open .qa-toggle { background: var(--burgundy); color: var(--ivory); border-color: var(--burgundy); }
        .qa-a { font-size: 14px; color: var(--text-mid); line-height: 1.8; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
        .qa-item.open .qa-a { max-height: 1200px; padding-bottom: 1.25rem; }
        :global(.qa-a p) { margin: 0 0 0.75em; }
        :global(.qa-a p:last-child) { margin-bottom: 0; }
        :global(.qa-a .bullet-block) { margin: 0 0 0.75em; }
        :global(.qa-a .bullet-block div) { line-height: 1.6; margin-bottom: 0.3em; }
        :global(.qa-a .bullet-block div:last-child) { margin-bottom: 0; }
        :global(.qa-a ul) { margin: 0 0 0.75em; padding-left: 1.3em; }
        :global(.qa-a ul li) { list-style-type: disc; line-height: 1.6; margin-bottom: 0.3em; }
        :global(.qa-a ul li:last-child) { margin-bottom: 0; }
        :global(.qa-a .section-title) { color: var(--text-dark); font-weight: 500; margin: 0.75em 0 0.4em; }
        .qa-category-label { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin: 2.5rem 0 0.1rem; font-weight: 400; }
        .qa-category-label:first-child { margin-top: 0; }
    </style>

    <div class="page-header">
        <p class="page-eyebrow">{qa.eyebrow}</p>
        <h1 class="page-title">{qa.title}</h1>
    </div>

    <div class="content">
        <div id="qa-list">
            {qa.categories.map(cat => (
                <>
                    <p class="qa-category-label">{cat.label}</p>
                    {cat.items.map(item => (
                        <div class="qa-item">
                            <div class="qa-q" onclick="this.parentElement.classList.toggle('open'); this.querySelector('.qa-toggle').textContent = this.parentElement.classList.contains('open') ? '×' : '+'">
                                {item.q}
                                <span class="qa-toggle">+</span>
                            </div>
                            <div class="qa-a" set:html={item.a} />
                        </div>
                    ))}
                </>
            ))}
        </div>

        {/*TODO: enable again maybe? <div class="form-section">
            <h3 class="form-title">{qa.formTitle}</h3>
            <p class="form-desc">{qa.formDesc}</p>
            <div class="form-row"><label>{qa.nameLabel}</label><input type="text" id="q-name" placeholder={qa.namePlaceholder} /></div>
            <div class="form-row"><label>{qa.questionLabel}</label><textarea id="q-text" placeholder={qa.questionPlaceholder}></textarea></div>
            <button class="btn-submit" id="q-submit">{qa.submitBtn}</button>
            <div class="form-success" id="q-success">{qa.successMsg}</div>
        </div> */}
    </div>

    <script>
        document.getElementById('q-submit')?.addEventListener('click', () => {
            const name = (document.getElementById('q-name') as HTMLInputElement)?.value.trim();
            const text = (document.getElementById('q-text') as HTMLTextAreaElement)?.value.trim();
            if (!name || !text) return;
            const success = document.getElementById('q-success');
            if (success) success.style.display = 'block';
            (document.getElementById('q-name') as HTMLInputElement).value = '';
            (document.getElementById('q-text') as HTMLTextAreaElement).value = '';
        });
    </script>
</Layout>