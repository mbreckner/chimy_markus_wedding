---
import '../styles/global.css';
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
  page: string;
}

const { lang, page } = Astro.props;
const tr = t(lang);
const otherLang = lang === 'en' ? 'de' : 'en';

const prefix = lang === 'de' ? '/de' : '';
const otherPrefix = otherLang === 'de' ? '/de' : '';

const pages = ['', '/wedding', '/travel', '/qa', '/guestbook'];
const navKeys = ['home', 'wedding', 'travel', 'qa', 'guestbook'] as const;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Chimwemwe & Markus – Wedding September 12, 2026 in Lusaka, Zambia" />
    <title>Chimwemwe & Markus · 12.09.2026</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav>
      <a href={`${prefix}/`} class="nav-logo">C & M</a>
      <div class="nav-right">
        <div class="nav-links">
          {navKeys.map((key, i) => (
            <a href={`${prefix}${pages[i] || '/'}`} class={page === key ? 'active' : ''}>
              {tr.nav[key]}
            </a>
          ))}
        </div>
        <div class="lang-toggle">
          <a href={`${lang === 'en' ? '/de' : ''}${page === 'home' ? '/' : `/${page}`}`}
             class={lang === 'de' ? 'active' : ''}>DE</a>
          <span>|</span>
          <a href={`${lang === 'de' ? '' : ''}${page === 'home' ? '/' : `/${page}`}`}
             class={lang === 'en' ? 'active' : ''}>EN</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p class="footer-names">{tr.footer.names}</p>
      <p class="footer-date">{tr.footer.date}</p>
    </footer>

    <script>
      // Auto-detect browser language on first visit
      if (!localStorage.getItem('lang-set')) {
        const browserLang = navigator.language.toLowerCase();
        const isGerman = browserLang.startsWith('de');
        const isOnEnglish = !window.location.pathname.startsWith('/de');
        if (isGerman && isOnEnglish) {
          localStorage.setItem('lang-set', 'true');
          const path = window.location.pathname;
          window.location.href = '/de' + (path === '/' ? '/' : path);
        } else {
          localStorage.setItem('lang-set', 'true');
        }
      }
    </script>
  </body>
</html>